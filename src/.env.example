# Copy this file to ".env" and fill in real values. Never commit ".env".

# Generate a new key for each environment, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Logging level for Django and the app (DEBUG, INFO, WARNING, ERROR). Optional.
DJANGO_LOG_LEVEL=INFO

DB_NAME=oees_inventory
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# Email via Resend — used for password reset and staff inventory reports.
# Create an API key at https://resend.com and verify your sending domain.
RESEND_API_KEY=re_your_api_key
# Must be an address on a domain verified in Resend (or onboarding@resend.dev for tests).
DEFAULT_FROM_EMAIL=onboarding@resend.dev
# Set to False only for local dev on macOS (python.org Python lacks a CA bundle).
# RESEND_VERIFY_SSL=True
# Recipient of the staff inventory reports (e.g. the People department).
STAFF_REPORT_RECIPIENT=people@example.com

# --- Omada (TP-Link) Open API ---
# From an app created in the controller (Settings -> Platform Integration -> Open API).
OMADA_BASE_URL=
OMADA_OMADAC_ID=
OMADA_CLIENT_ID=
OMADA_CLIENT_SECRET=

# --- Zyxel Nebula API (API key header: X-ZyxelNebula-API-Key) ---
NEBULA_BASE_URL=
NEBULA_ORG_ID=
NEBULA_API_KEY=
# NEBULA_VERIFY_SSL=True

# --- AnyDesk REST API (my.anydesk II, API v2) ---
# v2 auth is a single static token sent in the X-Api-Token header (the "API
# password" generated in the my.anydesk II console). Set it here:
ANYDESK_API_TOKEN=
# ANYDESK_API_URL defaults to https://my.anydesk.com (endpoints under /api/v2/).
# NOTE: my.anydesk.com is behind Cloudflare's managed challenge; calls may be
# blocked (HTTP 403) from some networks — validate from the server's IP.
# Legacy v1 (HMAC) creds — no longer used by the client; leave blank:
ANYDESK_API_LICENSE=
ANYDESK_API_KEY=
# Set to False only for local dev on macOS (python.org Python lacks a CA bundle).
# ANYDESK_VERIFY_SSL=True

# --- Logitech Sync Cloud API (mTLS — client certificate + private key) ---
# Place the cert/key in src/certs/ (gitignored). Defaults point there.
LOGITECH_API_BASE_URL=
# LOGITECH_CERT_PATH=/abs/path/to/logitech_sync.pem
# LOGITECH_KEY_PATH=/abs/path/to/logitech_sync.key
# LOGITECH_VERIFY_SSL=True
