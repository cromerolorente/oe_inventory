# OE Inventory - environment variables.
# Copy to .env for local development, or set these as Environment Properties
# on the Elastic Beanstalk environment for production. NEVER commit real secrets.

# --- Core Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True                     # True for local dev; set False (or omit) in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production examples (EB + your domain):
# DJANGO_ALLOWED_HOSTS=oe-inventory-prod.eu-west-1.elasticbeanstalk.com,inventory.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
# DJANGO_CSRF_TRUSTED_ORIGINS=https://inventory.example.com,https://*.elasticbeanstalk.com
DJANGO_LOG_LEVEL=INFO

# --- HTTPS hardening (production only; leave unset in dev/tests) ---
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_HSTS_SECONDS=31536000

# --- Database (MySQL / MariaDB) ---
DB_NAME=oees_inventory
DB_USER=change-me
DB_PASSWORD=change-me
DB_HOST=localhost                     # in production: the RDS endpoint
DB_PORT=3306

# --- Email via Resend (password reset / staff reports) ---
# Create an API key at https://resend.com and verify your sending domain.
RESEND_API_KEY=
# Must be an address on a domain verified in Resend (or onboarding@resend.dev for tests):
DEFAULT_FROM_EMAIL=onboarding@resend.dev
# Recipient (People dept.) for the staff inventory report email:
STAFF_REPORT_RECIPIENT=

# --- Media storage on S3 (production). If AWS_STORAGE_BUCKET_NAME is unset,
#     uploads fall back to the local filesystem (fine for dev). ---
# AWS_STORAGE_BUCKET_NAME=oe-inventory-media
# AWS_S3_REGION_NAME=eu-west-1
# Credentials are optional if the EC2 instance has an IAM role with S3 access:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Omada (TP-Link) Open API ---
# From an app created in the controller (Settings -> Platform Integration -> Open API).
OMADA_BASE_URL=
OMADA_OMADAC_ID=
OMADA_CLIENT_ID=
OMADA_CLIENT_SECRET=

# --- Zyxel Nebula API (API key header: X-ZyxelNebula-API-Key) ---
NEBULA_BASE_URL=
NEBULA_ORG_ID=
NEBULA_API_KEY=
# NEBULA_VERIFY_SSL=True
