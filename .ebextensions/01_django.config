# Elastic Beanstalk (Python platform) configuration for OE Inventory.
# The Django project lives in src/, so the commands cd into it.

container_commands:
  01_collectstatic:
    command: "cd src && python manage.py collectstatic --noinput"

  # NOTE: migrations are intentionally NOT run automatically. This project
  # manages its DB schema manually and applies migrations with `--fake`.
  # After the first deploy (and after restoring the DB dump into RDS), run:
  #     eb ssh
  #     cd /var/app/current/src
  #     source "$(find /var/app/venv -name activate | head -1)"
  #     python manage.py migrate --fake
